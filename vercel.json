{
  "version": 3,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    },
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/robots.txt$",
      "dest": "/dist/client/robots.txt"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/dist/server/server.js"
    }
  ],
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs20.x"
    }
  }
}
